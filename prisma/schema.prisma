// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Categories model
model Category {
  id          String  @id @default(cuid()) // Primary key
  name        String
  description String?

  // Relations
  lessons Lesson[] // 1 Category has many Lessons
}

// Lessons model
model Lesson {
  id              String   @id @default(cuid()) // Primary key
  title           String
  description     String?
  difficultyLevel String
  categoryId      String // Foreign key
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  category     Category       @relation(fields: [categoryId], references: [id])
  exercises    Exercise[] // 1 Lesson has many Exercises
  userProgress UserProgress[] // 1 Lesson has many UserProgress
}

// Exercises model
model Exercise {
  id       String  @id @default(cuid()) // Primary key
  lessonId String // Foreign key
  type     String
  question String
  answer   String
  hint     String?
  mediaUrl String?

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id])
}

enum Roles {
  ADMIN
  USER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
}

// Users model
model User {
  id           String   @id @default(cuid()) // Primary key
  username     String   @unique
  email        String   @unique
  password     String?
  token        String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Roles
  role               Roles              @default(USER)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)

  // Relations
  userProgress UserProgress[] // 1 User has many UserProgress
}

// User_Progress model
model UserProgress {
  id               String   @id @default(cuid()) // Primary key
  userId           String // Foreign key
  lessonId         String // Foreign key
  completionStatus String
  score            Int
  lastAccessed     DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])
}
